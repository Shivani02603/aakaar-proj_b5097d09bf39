# Database connection string for PostgreSQL with pgvector
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rag_document_qa

# Secret key for JWT token generation and verification
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# Port on which the FastAPI backend will run
PORT=8000

# Base URL for the backend API, used by the frontend
VITE_API_URL=http://localhost:8000

# OpenAI API key for generating embeddings (text-embedding-3-small)
OPENAI_API_KEY=your_openai_api_key_here

# Google Generative AI API key for Gemini 2.0 Flash model
GOOGLE_API_KEY=your_google_api_key_here

# PostgreSQL database user (used by the database service)
POSTGRES_USER=postgres

# PostgreSQL database password (used by the database service)
POSTGRES_PASSWORD=postgres

# PostgreSQL database name (used by the database service)
POSTGRES_DB=rag_document_qa

# Alembic database connection URL for migrations (can be same as DATABASE_URL)
ALEMBIC_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rag_document_qa